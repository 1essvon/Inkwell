/* ==========================================
   Progress Bar
========================================== */

QProgressBar {

    min-height: 8px;
    max-height: 8px;

    border: none;

    border-radius: 4px;

    background-color: #2F2F2F;

    text-align: center;
}

QProgressBar::chunk {

    border-radius: 4px;

    background-color: #FFFFFF;
}