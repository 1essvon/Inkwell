/* ==========================
   Search Bar
========================== */

#searchInput {

    min-height: 34px;

    border: 1px solid #444;

    border-radius: 8px;

    padding-left: 10px;

    background: #2A2A2A;

    color: white;
}

#searchInput:focus {

    border: 1px solid #4F8EF7;
}

#searchIcon {

    color: #888;

    font-size: 16px;
}