QMainWindow {
    background: #F7F5F2;
}

QWidget {
    background: #F7F5F2;
    color: #222222;
    font-size: 13px;
}

QPushButton {
    background: white;
    border: 1px solid #D8D8D8;
    border-radius: 8px;
    padding: 8px;
}

QPushButton:hover {
    background: #EFEFEF;
}

QLineEdit,
QTextEdit,
QSpinBox,
QComboBox,
QListWidget {

    background: white;
    border: 1px solid #D8D8D8;
    border-radius: 8px;
    padding: 6px;
}